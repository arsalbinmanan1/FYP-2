# DVC Ignore File
# Files and directories to ignore when running DVC commands

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.env

# Jupyter Notebook
.ipynb_checkpoints/

# Node.js (frontend)
frontend/node_modules/
frontend/.next/
frontend/out/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Test outputs
test_output/
test_results/

# Local config (don't version)
.env.local
*.local.yaml

