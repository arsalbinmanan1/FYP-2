# ============================================================
# VisionAI - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git (it's in .gitignore)

# ── DagsHub Credentials ──
# Get your token at: https://dagshub.com/user/settings/tokens
DAGSHUB_USER_TOKEN=your_dagshub_token_here
DAGSHUB_OWNER=arsal6010
DAGSHUB_REPO=FYP_visionAI

# ── MLflow (auto-set via DagsHub, override if self-hosted) ──
# MLFLOW_TRACKING_URI=https://dagshub.com/arsal6010/FYP_visionAI.mlflow
# MLFLOW_TRACKING_USERNAME=arsal6010
# MLFLOW_TRACKING_PASSWORD=your_dagshub_token_here

# ── DVC Remote Auth (S3-compatible via DagsHub) ──
# These are used by `dvc push` / `dvc pull`
AWS_ACCESS_KEY_ID=your_dagshub_token_here
AWS_SECRET_ACCESS_KEY=your_dagshub_token_here

# ── Backend ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
